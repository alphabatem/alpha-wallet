{
  "name": "alpha-wallet",
  "version": "0.2.0",
  "description": "Open Source Solana Wallet",
  "private": true,
  "scripts": {
    "dev": "webpack serve --mode=development --config config/webpack.config.js",
    "watch": "webpack --mode=development --watch --config config/webpack.config.js",
    "build": "rimraf dist && webpack --mode=production --config config/webpack.config.js",
    "format": "prettier --write --ignore-unknown \"{config,public,src}/**/*.{html,css,js,ts,json}\"",
    "lint": "eslint \"src/**/*.{js,ts}\""
  },
  "devDependencies": {
    "assert": "^2.1.0",
    "copy-webpack-plugin": "^12.0.0",
    "css-loader": "^7.0.0",
    "eslint": "^9.0.0",
    "file-loader": "^6.2.0",
    "mini-css-extract-plugin": "^2.9.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "stream-browserify": "^3.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@metaplex-foundation/mpl-token-metadata": "^3.4.0",
    "@project-serum/anchor": "^0.29.0",
    "@solana/spl-token": "^0.4.0",
    "@solana/web3.js": "^1.95.0",
    "axios": "^1.6.8",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "crypto-js": "^4.2.0",
    "ed25519-hd-key": "^1.3.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead"
  ],
  "browser": {
    "fs": false,
    "path": false,
    "os": false,
    "crypto": false,
    "stream": false
  }
}